{
  "expo": {
    "name": "Pension Tracker",
    "slug": "pension-tracker",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "pension-tracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dancmrobson.pensiontracker",
      "icon": "./assets/images/icon.png"
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-screen-orientation",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Pension Tracker to access your photo library to upload pension screenshots."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
